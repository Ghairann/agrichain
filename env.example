# ─── AgriChain — Environment Variables Template ─────────────────────────────
# Salin file ini menjadi .env dan isi nilainya.
# JANGAN commit file .env ke GitHub — file ini sudah ada di .gitignore!

# ─── Sepolia Testnet (opsional — hanya jika deploy ke Sepolia) ───────────────
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
PRIVATE_KEY=YOUR_WALLET_PRIVATE_KEY_TANPA_PREFIX_0x
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY_OPTIONAL

# ─── Catatan Localhost ────────────────────────────────────────────────────────
# Untuk development localhost, file .env TIDAK diperlukan.
# Cukup jalankan:
#   npm run node          (Terminal 1)
#   npm run deploy:local  (Terminal 2)
# Alamat kontrak akan otomatis ditulis ke frontend/.env.local
